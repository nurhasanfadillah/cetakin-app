# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Midtrans Configuration (Client-side)
# Get these from your Midtrans dashboard > Settings > Access Keys
VITE_MIDTRANS_CLIENT_KEY=your-client-key-here

# Midtrans Configuration (Server-side - for Edge Functions)
MIDTRANS_SERVER_KEY=your-server-key-here

# Midtrans Environment
MIDTRANS_ENVIRONMENT=sandbox
# Options: sandbox | production

# Site Configuration
VITE_SITE_URL=https://cetakin.com
VITE_SITE_NAME=CetakIn

# Supabase Service Role Key (for Edge Functions - NEVER expose this!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here