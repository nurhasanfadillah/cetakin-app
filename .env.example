# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Midtrans Configuration (Client-side ONLY)
# Get these from your Midtrans dashboard > Settings > Access Keys
VITE_MIDTRANS_CLIENT_KEY=your-client-key-here
VITE_MIDTRANS_IS_PRODUCTION=false

# ⚠️ SERVER-SIDE KEYS — DO NOT prefix with VITE_
# Set these in Supabase Edge Function env or Netlify environment variables:
# MIDTRANS_SERVER_KEY=your-server-key-here
# MIDTRANS_MERCHANT_ID=your-merchant-id-here

# Site Configuration
VITE_APP_URL=http://localhost:5173
VITE_SITE_URL=https://cetakin.com
VITE_SITE_NAME=CetakIn

# Supabase Service Role Key (for Edge Functions - NEVER expose this!)
# Set in Supabase dashboard > Edge Functions > Environment Variables
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here